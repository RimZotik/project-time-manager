{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Time Manager",
  "version": "0.1.14",
  "identifier": "com.projecttimemanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Project Time Manager",
        "width": 1500,
        "height": 900,
        "minWidth": 1500,
        "minHeight": 900,
        "resizable": true
      }
    ]
  },
  "mainBinaryName": "ProjectTimeManager",
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "template": "windows/installer-template.nsi",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    }
  }
}
